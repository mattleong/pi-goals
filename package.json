{
  "name": "pi-goal",
  "version": "0.1.0",
  "description": "A Codex-style persistent /goal workflow for pi.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "goal",
    "codex",
    "agent"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "goal-core.mjs",
    "goal-store.mjs",
    "migrations",
    "README.md",
    "LICENSE",
    "tsconfig.json",
    "test"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "smoke:pi": "pi -e . --list-models",
    "check": "npm test && npm run smoke:pi",
    "pack:dry": "npm pack --dry-run",
    "validate": "npm run check && npm run pack:dry"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "pi-code-previews": "^0.1.21"
  }
}
